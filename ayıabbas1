runService.Heartbeat:Connect(function()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    pcall(function()
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("TextLabel") and v:FindFirstAncestorOfClass("BillboardGui") and not v:FindFirstAncestor("MafyaMenuV7") then
                if v.Text == "Üye" or v.Name == "M4cirrRank" then
                    if _G.CustomRoleText ~= "" then
                        v.Name = "M4cirrRank" 
                        v.Text = _G.CustomRoleText
                        v.TextColor3 = Color3.fromRGB(255, 255, 255) 
                        v.TextTransparency = 0 
                        v.TextStrokeTransparency = 0
                        v.Font = Enum.Font.GothamBlack 
                    end
                end
            end
        end
    end)
    
    if _G.FlyAktif then
        player.Character.Humanoid.PlatformStand = true; local cam = workspace.CurrentCamera.CFrame; local moveDir = Vector3.new(0,0,0)
        if uis:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.LookVector end
        if uis:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.LookVector end
        if uis:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir + cam.RightVector end
        if uis:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.RightVector end
        if uis:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0,1,0) end
        if uis:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0,1,0) end
        if moveDir.Magnitude > 0 then hrp.CFrame = hrp.CFrame + (moveDir * flySpeed) end
        hrp.Velocity = Vector3.new(0, 0.1, 0)
    end
    
    if _G.OrbitAktif and targetBall then
        pcall(function()
            targetBall.CanCollide = false; targetBall.Velocity = Vector3.new(0,0,0)
            local offset = Vector3.new(math.cos(tick()*10)*8, 1.5, math.sin(tick()*10)*8)
            targetBall.CFrame = CFrame.new(hrp.Position + offset)
        end)
    end
    
    if _G.MagnetAktif or _G.FlingAktif then
        pcall(function()
            local slowSpeed = tick() * 2 
            local stormSpeed = tick() * 25 
            for i, v in pairs(objectCache) do
                if v and v.Parent and not v.Anchored then
                    local dist = (v.Position - hrp.Position).Magnitude
                    if dist < 60 then
                        local objSize = v.Size.Magnitude 
                        
                        if _G.FlingAktif then
                            local offsetAngle = stormSpeed + (i * 0.5)
                            local dynRadius = 6 + (objSize / 1.5)
                            local targetPos = hrp.Position + Vector3.new(math.cos(offsetAngle) * dynRadius, 1.5, math.sin(offsetAngle) * dynRadius)
                            
                            v.Velocity = (targetPos - v.Position) * 150 
                            v.RotVelocity = Vector3.new(0, 50000, 0) 
                            
                        elseif _G.MagnetAktif then
                            local offsetAngle = slowSpeed + (i * 0.5)
                            local dynRadius = 4 + (objSize / 3)
                            local floatHeight = 8 + math.sin(tick()*2 + i) 
                            local targetPos = hrp.Position + Vector3.new(math.cos(offsetAngle) * dynRadius, floatHeight, math.sin(offsetAngle) * dynRadius)
                            
                            v.Velocity = (targetPos - v.Position) * 30 
                            v.RotVelocity = Vector3.new(0, 0, 0) 
                        end
                    end
                end
            end
        end)
    end
    
    -- FANFİNFON 🤰
    if _G.StalkerAktif and stalkTarget and stalkTarget.Character then
        local targetHrp = stalkTarget.Character:FindFirstChild("HumanoidRootPart")
        if targetHrp then 
            local baseOffset = CFrame.new(0, 0.6, 1.0) 
            local zPump = math.sin(tick() * 25) * 0.5
            local pumpOffset = CFrame.new(0, 0, zPump)
            local leanForward = CFrame.Angles(math.rad(-25), 0, 0)
            
            hrp.CFrame = targetHrp.CFrame * baseOffset * pumpOffset * leanForward
            hrp.Velocity = Vector3.new(0, 0, 0) 
        end
    end
end)

