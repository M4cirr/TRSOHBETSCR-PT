task.spawn(function()
    while task.wait(1.5) do 
        local tempMoney = {}
        local tempObj = {}
        local allParts = workspace:GetDescendants()
        
        for i = 1, #allParts do
            if i % 1500 == 0 then task.wait() end 
            local v = allParts[i]
            if v:IsA("BasePart") then
                if v.Transparency < 0.5 and not blacklist[v] and v.Size.X < 4 and v.Size.Z < 4 then
                    local n = v.Name:lower()
                    local pName = v.Parent and v.Parent.Name:lower() or ""
                    if not n:find("table") and not n:find("masa") and not n:find("speed") and not n:find("spawn") and not pName:find("table") and not pName:find("masa") then
                        if v:FindFirstChildOfClass("TouchTransmitter") or n:find("para") or n:find("money") or n:find("cash") or n:find("deste") then
                            if v:IsDescendantOf(workspace) then table.insert(tempMoney, v) end
                        end
                    end
                end
                
                if (_G.MagnetAktif or _G.FlingAktif) and not v.Anchored and v.Size.Magnitude < 20 and v ~= targetBall then
                    if not v.Parent:FindFirstChild("Humanoid") and not v.Parent.Parent:FindFirstChild("Humanoid") then
                        table.insert(tempObj, v)
                    end
                end
            end
        end
        moneyCache = tempMoney
        objectCache = tempObj
    end
end)

